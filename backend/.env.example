# Copy to .env when you want to run the Postgres version (server-pg.js).
# The MySQL version (server.js) uses DB_HOST/DB_USER/... vars — both can coexist.

PORT=3001

# Option A — connection string (recommended for hosted Postgres: Neon, Supabase, Render)
# PG_URL=postgres://user:password@host:5432/dbname
# If you use a managed provider that requires SSL, leave PG_SSL unset; we default to
# { rejectUnauthorized: false }. For local Postgres without SSL, set PG_SSL=false.
# PG_SSL=false

# Option B — discrete variables (for local Postgres)
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=
PG_DATABASE=carmodel_shop

# Auth + admin bootstrap (shared with MySQL version)
TOKEN_SECRET=change-me-super-secret
ADMIN_EMAIL=admin@shop.local
ADMIN_PASSWORD=admin123
ADMIN_NAME=admin
